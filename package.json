{
  "name": "child-growth-charts",
  "version": "1.0.0",
  "description": "Web app to create WHO child growth charts",
  "private": true,
  "scripts": {
    "start": "webpack --watch --mode=development",
    "build": "webpack build --mode=production",
    "test": "tsx node_modules/.bin/ospec test/**/*.spec.ts --preload test/test-setup.ts",
    "lint": "biome check",
    "compile": "tsc",
    "fix": "biome check --fix",
    "prepare": "npm run compile",
    "pretest": "npm run compile",
    "postinstall": "ln -sf ../ospec/bin/ospec node_modules/.bin/ospec"
  },
  "keywords": [],
  "author": "Frederik Leonhardt <frederik.leonhardt@gmail.com>",
  "license": "ISC",
  "engines": {
    "node": ">=20 <25"
  },
  "dependencies": {
    "@js-joda/core": "^6.0.1",
    "chartist": "^1.3.0",
    "mithril": "^2.3.8"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/jsdom": "^21.1.7",
    "@types/mithril": "^2.2.6",
    "@types/node": "^24.12.2",
    "@types/ospec": "^4.0.10",
    "css-loader": "^6.11.0",
    "html-webpack-plugin": "^5.6.0",
    "jsdom": "^24.1.3",
    "mini-css-extract-plugin": "^2.9.0",
    "mithril-query": "github:mithriljs/mithril-query#e748bbf",
    "ospec": "^4.2.0",
    "sass": "^1.75.0",
    "sass-loader": "^14.2.1",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.1",
    "tsx": "^4.17.0",
    "typescript": "^5.6.3",
    "webpack": "^5.91.0",
    "webpack-cli": "^7.0.2"
  }
}
